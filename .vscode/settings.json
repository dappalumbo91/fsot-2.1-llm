  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
  "python.analysis.extraPaths": [
    "${workspaceFolder}/llm/python",
    "${workspaceFolder}/fsot_core/python"
  ],
  "files.exclude": {
    "**/__pycache__": true,
    "fsot_core/rust/target": true,
    "fsot_core/cpp/build": true
