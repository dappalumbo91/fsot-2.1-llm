  "terminal.integrated.env.windows": {
    "FSOT_LLM_ROOT": "${workspaceFolder}",
    "FSOT_ARCHIVE_ROOT": "I:\\FSOT-Physical-Archive",
    "FSOT_PORTABLE": "1"
  }
}
